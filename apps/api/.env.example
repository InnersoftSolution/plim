# Porta da API
PORT=3333
# Ambiente: development | test | production
NODE_ENV=development

# Supabase (opcional). Preenchido → API usa Postgres + valida JWT.
# SUPABASE_URL: Project Settings → API → Project URL
# SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → service_role (SECRETO, nunca no front)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# IA do copiloto (opcional). Sem a chave, o Plim usa só insights determinísticos (custo zero).
# ANTHROPIC_API_KEY: console.anthropic.com → API Keys
# PLIM_ADVISOR_MODEL: padrão claude-haiku-4-5 (mais barato). Opções: claude-sonnet-4-6, claude-opus-4-8
ANTHROPIC_API_KEY=
PLIM_ADVISOR_MODEL=
